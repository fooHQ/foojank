{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.13.6/.schema/devbox.schema.json",
  "packages": [
    "go@1.25.0",
    "golangci-lint@2.4.0"
  ],
  "env": {
    "GOROOT":      "",
    "GOPATH":      "",
    "CGO_ENABLED": "0"
  },
  "shell": {
    "init_hook": [
      "echo 'Welcome to devbox!' > /dev/null"
    ],
    "scripts": {
      "test": [
        "./devbox.sh test"
      ],
      "lint": [
        "./devbox.sh lint"
      ],
      "build-foojank-dev": [
        "./devbox.sh build_foojank_dev"
      ],
      "build-foojank-prod": [
        "./devbox.sh build_foojank_prod"
      ]
    }
  }
}
